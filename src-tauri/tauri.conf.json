{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "audiary",
  "version": "0.1.0",
  "identifier": "darae.studio.audiary",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Audiary",
        "width": 1200,
        "height": 600,
        "minWidth": 1200,
        "minHeight": 600,
        "decorations": true, 
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
